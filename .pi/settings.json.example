{
  "$comment": "Plantilla de settings de Pi para este repo. Copiá a .pi/settings.json si el tuyo no existe o querés resetearlo. NO pongas secretos ni rutas absolutas con tu usuario acá: los secretos van por entorno (ver .env.example) y este archivo se commitea. Los paths de packages son relativos a .pi/, por eso apuntan a ../extensions/*. El campo theme usa el formato light/dark y resuelve los JSON en .pi/themes/.",
  "theme": "panda-syntax-light/panda-syntax-dark",
  "packages": [
    "../extensions/pi-dynamic-workflows",
    "../extensions/pi-loop",
    "../extensions/pi-goal",
    "../extensions/pi-plan",
    "../extensions/pi-bg",
    "../extensions/pi-effort",
    "../extensions/pi-mdview",
    "../extensions/pi-local-memory",
    "../extensions/pi-auto-compact",
    "../extensions/pi-worktree",
    "../extensions/pi-container",
    "../extensions/pi-typescript-lsp",
    "../extensions/pi-rename",
    "../extensions/pi-btw",
    "../extensions/pi-pandi",
    "../extensions/pi-exit",
    "../extensions/pi-clear",
    "../extensions/pi-ask",
    "../extensions/pi-doctor"
  ],
  "extensions": []
}
