{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",

	// Aligned with the house config in ../pandi-code/biome.json: same formatter
	// (tabs, indentWidth 3, lineWidth 120) and the same permissive rule set.
	// One thing stays repo-specific because pandi-code's values do not apply here:
	//   - files.includes + vcs: pandi-code uses a monorepo `packages/*` allowlist;
	//     our sources live under extensions/, so we include ** and exclude noise.
	// (Workflow prompts use template literals — in scaffolds/*.js and test fixtures —
	// so the recommended noTemplateCurlyInString rule stays ON, matching pandi-code.)
	// Markdown stays with markdownlint-cli2 and types stay with `tsc`.

	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},

	"linter": {
		"enabled": true,
		"rules": {
			// pandi-code uses the now-deprecated `recommended: true`; on our newer
			// Biome (2.5) this is the identical, non-deprecated spelling.
			"preset": "recommended",
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},

	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},

	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!.pi",
			// `.claude` is Claude Code's project config/tooling dir (analogous to `.pi`):
			// it holds dynamic-workflow SCAFFOLDS (top-level `return` + template-literal
			// prompts => not parseable as standalone modules) and their tooling.
			// Lint the maintained sources under extensions/ instead, like `.pi`.
			// .claude/workflows/*.js are GENERATED from the canonical pi scaffolds by
			// .claude/scripts/generate-claude-workflows.mjs (`npm run format:claude`);
			// do not hand-edit them — the claude-parity test guards them. They are
			// prettier-formatted (biome can't parse their top-level `return`).
			"!.claude",
			// extensions/*/skills/ are GENERATED vendored mirrors of the canonical .pi/skills/
			// (scripts/vendor-extension-skills.mjs; parity-guarded). Their reference/*.js are
			// scaffolds with top-level `return` (not parseable as modules), same as .claude —
			// lint the canonical source, not the generated copy.
			"!extensions/*/skills",
			"!dist",
			"!.cache",
			"!coverage",
			"!package-lock.json",
			"!skills-lock.json",
			"!pi-session-*.html",
			"!**/*.md"
		]
	}
}
