# .env.example — configuración opcional de las extensiones (todas tienen defaults sensatos).
#
# Copiá a `.env` SOLO si necesitás cambiar algún default. Pi/las extensiones leen estas
# variables del entorno del proceso; este repo no carga `.env` automáticamente, así que
# exportalas en tu shell o mediante tu gestor de entorno (p. ej. `direnv`, `dotenvx`).
# NUNCA pongas secretos acá: `.env` está gitignoreado, pero `.env.example` se commitea.

# ─────────────────────────────────────────────────────────────────────────────
# Dynamic Workflows (pandi-dynamic-workflows) — también usado por pi-goal
# ─────────────────────────────────────────────────────────────────────────────
# Binario de Pi usado para spawnear subagentes (`pi -p --no-session`). Útil si `pi`
# no está en el PATH o querés apuntar a una versión concreta.
PI_DYNAMIC_WORKFLOWS_PI_COMMAND=pi
# Profundidad máxima de anidación de workflows antes de rechazar start/run/resume.
# Poné 0 como kill-switch (desactiva TODA ejecución de workflows, incluso top-level).
PI_DYNAMIC_WORKFLOWS_MAX_DEPTH=2
# PI_DYNAMIC_WORKFLOWS_DEPTH lo setea el runtime al spawnear subagentes — NO lo definas a mano.

# ─────────────────────────────────────────────────────────────────────────────
# Auto-compactación de contexto (pi-auto-compact)
# ─────────────────────────────────────────────────────────────────────────────
PI_AUTO_COMPACT_PERCENT=35              # % de uso de contexto que dispara la compactación
PI_AUTO_COMPACT_BAR=on                  # barra de progreso de contexto en el footer
PI_AUTO_COMPACT_SNAPSHOT=on             # guardar snapshot recuperable antes de compactar
PI_AUTO_COMPACT_SNAPSHOT_KEEP=20        # cuántos snapshots retener
PI_AUTO_COMPACT_CLEAR_TOOL_RESULTS=off  # elidir tool results viejos por llamada (más liviano que compactar)
PI_AUTO_COMPACT_CLEAR_KEEP_RECENT=3     # cuántos tool results recientes preservar al elidir
PI_AUTO_COMPACT_CLEAR_MIN_CHARS=2000    # mínimo de chars antes de intentar elidir

# ─────────────────────────────────────────────────────────────────────────────
# Diagnósticos TypeScript (pi-typescript-lsp)
# ─────────────────────────────────────────────────────────────────────────────
PI_TS_LSP=on                            # on|off — habilita el feedback de tsc en agent_end
PI_TS_LSP_MODE=advisory                 # advisory (solo avisa) | autofix
PI_TS_LSP_MAX=20                        # máximo de errores a mostrar por invocación
PI_TS_LSP_AUTOFIX=off                   # intentar arreglar errores automáticamente
# PI_TS_LSP_TSC=/ruta/a/tsc.js          # tsc explícito (default: autodescubierto por node_modules/npx)

# ─────────────────────────────────────────────────────────────────────────────
# Plan mode (pi-plan)
# ─────────────────────────────────────────────────────────────────────────────
# PI_PLAN_NONINTERACTIVE=1              # permitir plan mode en print/json (p. ej. subagente); el plan es el entregable
# PI_PLAN_ULTRACODE=1                  # investigar/diseñar el plan con dynamic workflows
# PI_PLAN_ULTRACODE_STEPS=1            # ejecutar los pasos del plan con dynamic workflows cuando corresponda

# ─────────────────────────────────────────────────────────────────────────────
# Worktrees (pi-worktree) — tri-estado: true fuerza, false omite, ausente = default de sesión/off
# ─────────────────────────────────────────────────────────────────────────────
# PI_WORKTREE_COPY_IGNORED=false        # copiar gitignored (p. ej. node_modules) al crear un worktree
# PI_WORKTREE_COPY_UNTRACKED=false      # copiar untracked al crear un worktree

# ─────────────────────────────────────────────────────────────────────────────
# Rename de sesión (pi-rename)
# ─────────────────────────────────────────────────────────────────────────────
# PI_RENAME_PI_COMMAND=pi               # binario de pi para el subagente de resumen
# PI_RENAME_MODEL=anthropic/claude-haiku-4-5   # modelo para autogenerar el nombre

# ─────────────────────────────────────────────────────────────────────────────
# Búsqueda web (extensión externa pi-codex-web-search → CLI `codex`)
# ─────────────────────────────────────────────────────────────────────────────
# CODEX_PATH=/opt/homebrew/bin/codex    # ruta al binario codex si no está en el PATH
# (equivalente: PI_CODEX_WEB_SEARCH_CODEX_PATH)
