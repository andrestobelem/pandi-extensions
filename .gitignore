# macOS Finder metadata
.DS_Store
**/.DS_Store

# Pi project-local state
# Keep examples free of project-local Pi state; run example workflows from repo root or temp projects.
examples/.pi/

# Picante project state when the isolated dev TUI opens this checkout as its real workspace.
.picante/
# Legacy Picante project state from before the .picante migration.
.pi-cante/

# Claude Code project-local state (workflows/skills/scripts it creates); not tracked or linted.
.claude/
**/.claude/
# ...except the curated skills, workflows, and scripts we DO track.
!.claude/
!.claude/skills/
!.claude/skills/**
!.claude/workflows/
!.claude/workflows/**
!.claude/scripts/
!.claude/scripts/**

# Third-party skill installed LOCALLY (via the skill installer) but intentionally NOT
# vendored into this repo. Keep it usable on this machine without tracking ~4.8M of it.
# Reinstall globally (Pi auto-discovers it from ~/.agents/skills in any project) with:
#   ctx7 skills install /openprose/prose open-prose --global
.claude/skills/open-prose/
**/.claude/skills/open-prose/
.agents/skills/open-prose/
**/.agents/skills/open-prose/

# Pi background jobs and automation state.
.pi/bg/
**/.pi/bg/
.pi/goals/
**/.pi/goals/
.pi/loops/
**/.pi/loops/

# Pi workflow runtime artifacts.
.pi/workflows/runs/
**/.pi/workflows/runs/
.pi/workflows/graphs/
**/.pi/workflows/graphs/
.pi/workflows/drafts/
**/.pi/workflows/drafts/
.pi/workflows-archive/
**/.pi/workflows-archive/

# Pi local chats, sessions, and plans.
.pi/live-sessions/
**/.pi/live-sessions/
.pi/pandi-session/
**/.pi/pandi-session/
.pi/sessions/
**/.pi/sessions/
.pi/chats/
**/.pi/chats/
.pi/plans/
**/.pi/plans/
.pi/plan-artifacts/
**/.pi/plan-artifacts/
# Raw transcript snapshots written before auto-compaction (pandi-auto-compact #3.1).
.pi/compaction-snapshots/
**/.pi/compaction-snapshots/
# Stray native /export output (no path) lands a pi-session-*.html in the repo root.
pi-session-*.html

# Pi git worktrees scratch space and writer leases (pandi-worktree runtime state).
.pi/worktrees/
**/.pi/worktrees/
.pi/worktree-writer.json
**/.pi/worktree-writer.json
.pi/worktree-writer.json.lock
**/.pi/worktree-writer.json.lock

# Pi private memory and local extension plugins.
.pi/MEMORY.md
**/.pi/MEMORY.md
.pi/memory/
**/.pi/memory/
.pi/extensions/
**/.pi/extensions/

# pandi runtime state (chosen face style), not shipped/tracked.
extensions/pandi/*.local.json

# Pi project-local on-demand tools (e.g. Gondolin micro-VM; heavy platform-specific
# native deps installed via `npm run setup:gondolin`, loaded with `pi -e .pi/tools/gondolin`).
.pi/tools/
**/.pi/tools/

# Pi project-local scratch space.
.pi/tmp/
**/.pi/tmp/
.release-plan.json

# Pi project-local notes.
.pi/notes/
**/.pi/notes/

# Pi project-local persona backups (copies saved before overwriting a .pi/personas/*.json).
.pi/personas/backups/
**/.pi/personas/backups/

# Logs and diagnostics
logs
.logs/
**/.logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Process/runtime files
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/
web_modules/
bower_components

