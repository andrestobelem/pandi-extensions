# Pi project-local state
# Keep examples free of project-local Pi state; run example workflows from repo root or temp projects.
examples/.pi/

# Pi background jobs and automation state.
.pi/bg/
**/.pi/bg/
.pi/goals/
**/.pi/goals/
.pi/loops/
**/.pi/loops/

# Pi workflow runtime artifacts.
.pi/workflows/runs/
**/.pi/workflows/runs/
.pi/workflows/graphs/
**/.pi/workflows/graphs/
.pi/workflows/drafts/
**/.pi/workflows/drafts/
.pi/workflows-archive/
**/.pi/workflows-archive/

# Pi local chats, sessions, and plans.
.pi/live-sessions/
**/.pi/live-sessions/
.pi/sessions/
**/.pi/sessions/
.pi/chats/
**/.pi/chats/
.pi/plans/
**/.pi/plans/
# Raw transcript snapshots written before auto-compaction (pi-auto-compact-context #3.1).
.pi/compaction-snapshots/
**/.pi/compaction-snapshots/
# Stray native /export output (no path) lands a pi-session-*.html in the repo root.
pi-session-*.html

# Pi git worktrees scratch space (default base for the pi-worktree extension).
.pi/worktrees/
**/.pi/worktrees/

# Pi private memory and local extension plugins.
.pi/MEMORY.md
**/.pi/MEMORY.md
.pi/memory/
**/.pi/memory/
.pi/extensions/
**/.pi/extensions/

# Pi project-local scratch space.
.pi/tmp/
**/.pi/tmp/

# Pi project-local notes.
.pi/notes/
**/.pi/notes/

# Logs and diagnostics
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Process/runtime files
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/
web_modules/
bower_components

# Package manager files and caches
.npm
.pnpm-store
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Environment files
.env
.env.*
!.env.example

# Build outputs
build/Release
dist
out
.next
.nuxt
.output
.vuepress/dist
**/.vitepress/dist
.docusaurus

# Caches and temporary files
.cache
.cache/
.parcel-cache
.temp
.svelte-kit/
**/.vitepress/cache
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Test and coverage output
coverage
*.lcov
.nyc_output
.vscode-test

# Tool-specific generated files
lib-cov
.grunt
.lock-wscript
.serverless/
.fusebox/
.dynamodb/
.firebase/
.tern-port
.node_repl_history
*.tgz
