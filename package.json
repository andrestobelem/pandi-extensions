{
	"name": "pandi-extensions",
	"version": "0.3.18",
	"private": true,
	"workspaces": [
		"extensions/pandi",
		"extensions/pandi-*"
	],
	"description": "Claude-style dynamic workflows for Pi: JavaScript orchestration scripts with parallel Pi subagents.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pandi-extensions.git"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"dynamic-workflows",
		"claude-code",
		"subagents"
	],
	"files": [
		"extensions/*/*.ts",
		"extensions/pandi-doctor/scripts/*.mjs",
		"extensions/pandi-docs/scripts/*.mjs",
		"extensions/pandi-docs/skills",
		"extensions/pandi-theme/themes/*.json",
		"extensions/pandi-dynamic-workflows/scaffolds/*.js",
		"extensions/pandi-personas/personas/*.json",
		".pi/skills",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"prepare": "node scripts/install-git-hooks.mjs",
		"dev:picante": "node scripts/dev-picante.mjs",
		"smoke:picante": "node scripts/dev-picante.mjs",
		"smoke:picante:tui": "node scripts/dev-picante.mjs",
		"typecheck": "tsc -p tsconfig.json",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check:staged": "npm run -s test:fast",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"format:claude": "node .claude/scripts/generate-claude-workflows.mjs",
		"format:claude:check": "node .claude/scripts/generate-claude-workflows.mjs --check",
		"sync:all": "node scripts/sync-all.mjs",
		"sync:check:all": "node scripts/sync-all.mjs --check",
		"sync:all:global": "node scripts/sync-all.mjs --global",
		"sync:manifest": "node scripts/sync-root-manifest.mjs",
		"sync:manifest:check": "node scripts/sync-root-manifest.mjs --check",
		"sync:settings": "node scripts/sync-project-settings.mjs",
		"sync:settings:check": "node scripts/sync-project-settings.mjs --check",
		"sync:skills": "node scripts/sync-skill-mirrors.mjs",
		"sync:skills:check": "node scripts/sync-skill-mirrors.mjs --check",
		"sync:skills:vendor": "node scripts/vendor-extension-skills.mjs",
		"sync:skills:vendor:check": "node scripts/vendor-extension-skills.mjs --check",
		"sync:agents": "node scripts/sync-agent-guides.mjs",
		"sync:agents:check": "node scripts/sync-agent-guides.mjs --check",
		"sync:scaffold-catalog": "node scripts/sync-scaffold-catalog.mjs",
		"sync:scaffold-catalog:check": "node scripts/sync-scaffold-catalog.mjs --check",
		"sync:claude:global": "node scripts/sync-claude-global.mjs status",
		"sync:claude:global:status": "node scripts/sync-claude-global.mjs status",
		"sync:claude:global:install": "node scripts/sync-claude-global.mjs install",
		"sync:claude:global:remove": "node scripts/sync-claude-global.mjs remove",
		"sync:claude:global:check": "node scripts/sync-claude-global.mjs --check",
		"sync:agents:global": "node scripts/sync-agents-global.mjs status",
		"sync:agents:global:status": "node scripts/sync-agents-global.mjs status",
		"sync:agents:global:install": "node scripts/sync-agents-global.mjs install",
		"sync:agents:global:remove": "node scripts/sync-agents-global.mjs remove",
		"sync:agents:global:check": "node scripts/sync-agents-global.mjs --check",
		"sync:claude:ultracode": "node scripts/generate-claude-ultracode-skills.mjs",
		"sync:claude:ultracode:check": "node scripts/generate-claude-ultracode-skills.mjs --check",
		"lint:md": "markdownlint-cli2",
		"docs:links:check": "node scripts/check-doc-catalog-and-links.mjs",
		"md:html": "node extensions/pandi-docs/scripts/markdown-to-html.mjs",
		"sync:docs:html": "node scripts/sync-docs-html.mjs",
		"sync:docs:html:check": "node scripts/sync-docs-html.mjs --check",
		"sync:personas": "node scripts/sync-personas-readme.mjs",
		"sync:personas:check": "node scripts/sync-personas-readme.mjs --check",
		"sync:personas:package": "node scripts/sync-personas-package.mjs",
		"sync:personas:package:check": "node scripts/sync-personas-package.mjs --check",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"release:prepare": "node scripts/release-prepare.mjs",
		"release:prepare:write": "node scripts/release-prepare.mjs --write",
		"release:contract": "node scripts/release-contract.mjs",
		"release:flow": "node scripts/release-flow.mjs",
		"release:go": "node scripts/release-flow.mjs --go",
		"publish:npm": "node scripts/publish-npm.mjs",
		"publish:npm:go": "node scripts/publish-npm.mjs --publish",
		"doctor": "node extensions/pandi-doctor/scripts/doctor.mjs",
		"setup:gondolin": "node scripts/setup-gondolin.mjs",
		"setup:gondolin:test-fixture": "node scripts/ensure-gondolin-test-fixture.mjs",
		"test:unit": "npm run setup:gondolin:test-fixture && node --test \"scripts/test/unit/*.test.mjs\"",
		"test:integration": "node scripts/test/run-all.mjs",
		"test:fast": "npm run typecheck && npm run check && npm run lint:md && npm run sync:check:all && node scripts/check-extension-boundaries.mjs && node scripts/check-package-files.mjs && npm run test:unit",
		"test": "npm run typecheck && npm run check && npm run lint:md && npm run sync:docs:html:check && npm run sync:personas:check && npm run sync:personas:package:check && node scripts/check-extension-boundaries.mjs && node scripts/check-package-files.mjs && npm run test:unit && npm run test:integration"
	},
	"pi": {
		"extensions": [
			"./extensions/pandi-dynamic-workflows/index.ts",
			"./extensions/pandi-personas/index.ts",
			"./extensions/pandi-session/index.ts",
			"./extensions/pandi-loop/index.ts",
			"./extensions/pandi-goal/index.ts",
			"./extensions/pandi-plan/index.ts",
			"./extensions/pandi-bg/index.ts",
			"./extensions/pandi-effort/index.ts",
			"./extensions/pandi-mdview/index.ts",
			"./extensions/pandi-docs/index.ts",
			"./extensions/pandi-local-memory/index.ts",
			"./extensions/pandi-auto-compact/index.ts",
			"./extensions/pandi-worktree/index.ts",
			"./extensions/pandi-kitty/index.ts",
			"./extensions/pandi-container/index.ts",
			"./extensions/pandi-podman/index.ts",
			"./extensions/pandi-typescript-lsp/index.ts",
			"./extensions/pandi-rename/index.ts",
			"./extensions/pandi-btw/index.ts",
			"./extensions/pandi-improve-prompt/index.ts",
			"./extensions/pandi/index.ts",
			"./extensions/pandi-exit/index.ts",
			"./extensions/pandi-clear/index.ts",
			"./extensions/pandi-ask/index.ts",
			"./extensions/pandi-doctor/index.ts",
			"./extensions/pandi-anthropic-web-search/index.ts",
			"./node_modules/pi-codex-web-search/src/index.ts",
			"./node_modules/pi-mcp-adapter/index.ts",
			"./node_modules/pi-cursor-sdk/src/index.ts"
		],
		"skills": [
			"./.pi/skills"
		],
		"themes": [
			"./extensions/pandi-theme/themes"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.80.3",
		"@earendil-works/pi-coding-agent": "^0.80.3",
		"@earendil-works/pi-tui": "^0.80.3",
		"typebox": "^1.1.38"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/sanitize-html": "^2.16.1",
		"ctx7": "^0.5.3",
		"esbuild": "^0.25.12",
		"markdownlint-cli2": "^0.22.1",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3"
	},
	"optionalDependencies": {
		"@mermaid-js/mermaid-cli": "^11.15.0"
	},
	"allowScripts": {
		"esbuild@0.25.12": true,
		"puppeteer@24.43.1": true
	},
	"dependencies": {
		"pi-codex-web-search": "0.1.9",
		"pi-cursor-sdk": "0.1.57",
		"pi-mcp-adapter": "2.11.0"
	},
	"bundledDependencies": [
		"pi-codex-web-search",
		"pi-mcp-adapter",
		"pi-cursor-sdk"
	]
}
