{
  "name": "pi-dynamic-workflows",
  "version": "0.1.0",
  "description": "Claude-style dynamic workflows for Pi: JavaScript orchestration scripts with parallel Pi subagents.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "dynamic-workflows",
    "claude-code",
    "subagents"
  ],
  "files": [
    "extensions",
    "skills",
    "examples/workflows",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "tsc --noEmit --skipLibCheck --target ES2022 --module NodeNext --moduleResolution NodeNext extensions/dynamic-workflows.ts extensions/loop.ts extensions/goal.ts extensions/plan.ts extensions/compaction-progress.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/dynamic-workflows.ts",
      "./extensions/loop.ts",
      "./extensions/goal.ts",
      "./extensions/plan.ts",
      "./extensions/compaction-progress.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0"
  }
}
