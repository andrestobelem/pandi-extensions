{
	"name": "pandi-extensions",
	"version": "0.2.0",
	"private": true,
	"workspaces": [
		"extensions/pandi",
		"extensions/pandi-*"
	],
	"description": "Claude-style dynamic workflows for Pi: JavaScript orchestration scripts with parallel Pi subagents.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pandi-extensions.git"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"dynamic-workflows",
		"claude-code",
		"subagents"
	],
	"files": [
		"extensions/*/*.ts",
		"extensions/pandi-doctor/scripts/*.mjs",
		"extensions/pandi-docs/scripts/*.mjs",
		"extensions/pandi-docs/skills",
		"extensions/pandi-theme/themes/*.json",
		"extensions/pandi-dynamic-workflows/scaffolds/*.js",
		".pi/skills",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"prepare": "node scripts/install-git-hooks.mjs",
		"typecheck": "tsc -p tsconfig.json",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"format:claude": "node .claude/scripts/generate-claude-workflows.mjs",
		"format:claude:check": "node .claude/scripts/generate-claude-workflows.mjs --check",
		"sync:check:all": "npm run -s format:claude:check && npm run -s sync:manifest:check && npm run -s sync:skills:check && npm run -s sync:skills:vendor:check && npm run -s sync:agents:check && npm run -s sync:claude:ultracode:check && npm run -s docs:links:check && npm run -s sync:docs:html:check && npm run -s sync:personas:check",
		"sync:manifest": "node scripts/sync-root-manifest.mjs",
		"sync:manifest:check": "node scripts/sync-root-manifest.mjs --check",
		"sync:skills": "node scripts/sync-skill-mirrors.mjs",
		"sync:skills:check": "node scripts/sync-skill-mirrors.mjs --check",
		"sync:skills:vendor": "node scripts/vendor-extension-skills.mjs",
		"sync:skills:vendor:check": "node scripts/vendor-extension-skills.mjs --check",
		"sync:agents": "node scripts/sync-agent-guides.mjs",
		"sync:agents:check": "node scripts/sync-agent-guides.mjs --check",
		"sync:claude:global": "node scripts/sync-claude-global.mjs",
		"sync:claude:global:check": "node scripts/sync-claude-global.mjs --check",
		"sync:claude:ultracode": "node scripts/generate-claude-ultracode-skills.mjs",
		"sync:claude:ultracode:check": "node scripts/generate-claude-ultracode-skills.mjs --check",
		"lint:md": "markdownlint-cli2",
		"docs:links:check": "node scripts/check-doc-catalog-and-links.mjs",
		"md:html": "node extensions/pandi-docs/scripts/markdown-to-html.mjs",
		"sync:docs:html": "node scripts/sync-docs-html.mjs",
		"sync:docs:html:check": "node scripts/sync-docs-html.mjs --check",
		"sync:personas": "node scripts/sync-personas-readme.mjs",
		"sync:personas:check": "node scripts/sync-personas-readme.mjs --check",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"publish:npm": "node scripts/publish-npm.mjs",
		"publish:npm:go": "node scripts/publish-npm.mjs --publish",
		"doctor": "node extensions/pandi-doctor/scripts/doctor.mjs",
		"setup:gondolin": "node scripts/setup-gondolin.mjs",
		"test:unit": "node --test \"scripts/test/unit/*.test.mjs\"",
		"test:integration": "node scripts/test/run-all.mjs",
		"test": "npm run typecheck && npm run check && npm run lint:md && npm run sync:docs:html:check && npm run sync:personas:check && npm run test:unit && npm run test:integration"
	},
	"pi": {
		"extensions": [
			"./extensions/pandi-dynamic-workflows/index.ts",
			"./extensions/pandi-loop/index.ts",
			"./extensions/pandi-goal/index.ts",
			"./extensions/pandi-plan/index.ts",
			"./extensions/pandi-bg/index.ts",
			"./extensions/pandi-effort/index.ts",
			"./extensions/pandi-mdview/index.ts",
			"./extensions/pandi-docs/index.ts",
			"./extensions/pandi-local-memory/index.ts",
			"./extensions/pandi-auto-compact/index.ts",
			"./extensions/pandi-worktree/index.ts",
			"./extensions/pandi-container/index.ts",
			"./extensions/pandi-typescript-lsp/index.ts",
			"./extensions/pandi-rename/index.ts",
			"./extensions/pandi-btw/index.ts",
			"./extensions/pandi-improve-prompt/index.ts",
			"./extensions/pandi/index.ts",
			"./extensions/pandi-exit/index.ts",
			"./extensions/pandi-clear/index.ts",
			"./extensions/pandi-ask/index.ts",
			"./extensions/pandi-doctor/index.ts"
		],
		"skills": [
			"./.pi/skills"
		],
		"themes": [
			"./extensions/pandi-theme/themes"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.80.3",
		"@earendil-works/pi-coding-agent": "^0.80.3",
		"@earendil-works/pi-tui": "^0.80.3",
		"typebox": "^1.1.38"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/sanitize-html": "^2.16.1",
		"ctx7": "^0.5.3",
		"esbuild": "^0.25.12",
		"markdownlint-cli2": "^0.22.1",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3"
	},
	"optionalDependencies": {
		"@mermaid-js/mermaid-cli": "^11.15.0"
	},
	"allowScripts": {
		"esbuild@0.25.12": true,
		"puppeteer@24.43.1": true
	}
}
