{
	"name": "@pandi-coding-agent/mdhtml",
	"version": "0.1.0",
	"description": "Pi extension that converts Markdown into pandi-styled self-contained HTML artifacts (/mdhtml command + markdown_to_html tool).",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pi-dynamic-workflows.git",
		"directory": "extensions/pi-mdhtml"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"markdown",
		"html",
		"pandi"
	],
	"files": [
		"*.ts",
		"scripts/*.mjs",
		"scripts/*.d.mts",
		"skills",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"marked": "^18.0.5"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	}
}
