{
	"name": "@pandi-coding-agent/pandi-docs",
	"version": "0.1.10",
	"description": "Extensión de Pi que convierte Markdown en artifacts HTML autocontenidos con estilo pandi (/docs + tool markdown_to_html).",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pandi-extensions.git",
		"directory": "extensions/pandi-docs"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"markdown",
		"html",
		"pandi"
	],
	"files": [
		"*.ts",
		"scripts/*.mjs",
		"scripts/*.d.mts",
		"skills",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"highlight.js": "^11.11.1",
		"marked": "^18.0.5"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "^0.80.3",
		"typebox": "^1.1.38"
	}
}
