{
	"name": "@pandi-coding-agent/pandi-container",
	"version": "0.2.1",
	"description": "Pi extension to manage Apple `container` sandboxes (Linux micro-VMs): a /container command and a model-callable container_sandbox tool (status/list/create/run/stop/remove).",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pandi-extensions.git",
		"directory": "extensions/pandi-container"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"apple-container",
		"sandbox",
		"virtualization"
	],
	"files": [
		"index.ts",
		"container.ts",
		"notify.ts",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.80.3",
		"@earendil-works/pi-coding-agent": "^0.80.3",
