{
	"name": "@pandi-coding-agent/pandi-container",
	"version": "0.2.4",
	"description": "Extensión de Pi para administrar sandboxes de Apple `container` (micro-VMs Linux): un comando /container y una herramienta container_sandbox invocable por el modelo (status/list/create/run/stop/remove).",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrestobelem/pandi-extensions.git",
		"directory": "extensions/pandi-container"
	},
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"apple-container",
		"sandbox",
		"virtualization"
	],
	"files": [
		"index.ts",
		"command-menu.ts",
		"command.ts",
		"container.ts",
		"notify.ts",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.80.3",
		"@earendil-works/pi-coding-agent": "^0.80.3",
		"typebox": "^1.1.38"
	}
}
